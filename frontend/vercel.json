{
  "functions": {
    "api/auth.js":    { "memory": 256, "maxDuration": 10 },
    "api/books.js":   { "memory": 256, "maxDuration": 10 },
    "api/members.js": { "memory": 256, "maxDuration": 10 },
    "api/borrows.js": { "memory": 256, "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/auth/(.*)",    "destination": "/api/auth?sub=$1" },
    { "source": "/api/books/(.*)",   "destination": "/api/books?sub=$1" },
    { "source": "/api/members/(.*)", "destination": "/api/members?sub=$1" },
    { "source": "/api/borrows/(.*)", "destination": "/api/borrows?sub=$1" },
    { "source": "/(.*)",             "destination": "/index.html" }
  ]
}
